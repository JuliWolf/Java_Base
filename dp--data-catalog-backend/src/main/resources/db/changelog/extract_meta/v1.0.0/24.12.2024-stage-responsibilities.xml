<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">


  <changeSet id="1735063194838-1" author="juliwolf">
    <addColumn tableName="extract_job" schemaName="extract_meta">
      <column name="source_kind" type="varchar(15)"/>
    </addColumn>
  </changeSet>

  <changeSet id="1735061176327-1" author="juliwolf">
    <createTable schemaName="extract_delta" tableName="stage_responsibility">
        <column autoIncrement="true" name="stage_responsibility_id" type="BIGINT">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_stage_responsibility"/>
        </column>
        <column name="job_id" type="UUID"/>
        <column name="nk" type="text"/>
        <column name="role_id" type="UUID"/>
        <column name="asset_id" type="UUID"/>
        <column name="user_id" type="UUID"/>
        <column name="group_id" type="UUID"/>
        <column name="responsible_type" type="varchar(10)"/>
        <column name="asset_name_nk" type="text"/>
        <column name="inserted_datetime" type="DATETIME"/>
        <column name="action_decision" type="varchar(1)"/>
        <column name="action_process_status" type="VARCHAR(255)"/>
        <column name="matched_responsibility_id" type="UUID"/>
        <column name="created_responsibility_id" type="UUID"/>
        <column name="action_processed_datetime" type="DATETIME"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="job_id" baseTableName="stage_responsibility" baseTableSchemaName="extract_delta" constraintName="FK_STAGE_RESPONSIBILITY_ON_JOB" onDelete="CASCADE" referencedColumnNames="job_id" referencedTableName="extract_job" referencedTableSchemaName="extract_meta"/>
  </changeSet>

  <changeSet id="1735061147803-1" author="juliwolf">
    <sqlFile path="db/changelog/extract_meta/v1.0.0/fn_load_api_dpc_for_data_catalog.sql" splitStatements="false"/>
  </changeSet>
</databaseChangeLog>