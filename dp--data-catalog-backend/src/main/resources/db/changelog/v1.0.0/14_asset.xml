<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">

  <changeSet id="1697119772963-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="asset"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="asset" cascadeConstraints="true"/>
    </rollback>

    <createTable schemaName="public" tableName="asset">
        <column name="asset_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_asset"/>
        </column>
        <column name="asset_name" type="VARCHAR(255)"/>
        <column name="asset_type_id" type="UUID"/>
        <column name="asset_displayname" type="VARCHAR(255)"/>
        <column name="source_language" type="UUID"/>
        <column name="lifecycle_status" type="UUID"/>
        <column name="stewardship_status" type="UUID"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column name="last_modified_on" type="DATETIME"/>
        <column name="last_modified_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="asset_type_id" baseTableName="asset" baseTableSchemaName="public" constraintName="FK_ASSET_ON_ASSET_TYPE" referencedColumnNames="asset_type_id" referencedTableName="asset_type" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="asset" baseTableSchemaName="public" constraintName="FK_ASSET_ON_CREATE_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="asset" baseTableSchemaName="public" constraintName="FK_ASSET_ON_DELETED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="asset" baseTableSchemaName="public" constraintName="FK_ASSET_ON_LAST_MODIFIED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="lifecycle_status" baseTableName="asset" baseTableSchemaName="public" constraintName="FK_ASSET_ON_LIFECYCLE_STATUS" referencedColumnNames="status_id" referencedTableName="status" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="source_language" baseTableName="asset" baseTableSchemaName="public" constraintName="FK_ASSET_ON_SOURCE_LANGUAGE" referencedColumnNames="language_id" referencedTableName="language" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="stewardship_status" baseTableName="asset" baseTableSchemaName="public" constraintName="FK_ASSET_ON_STEWARDSHIP_STATUS" referencedColumnNames="status_id" referencedTableName="status" referencedTableSchemaName="public"/>
  </changeSet>

  <changeSet id="1697119838708-1" author="JuliWolf" dbms="postgresql">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="asset" columnName="asset_name"/>

      <columnExists tableName="asset" columnName="deleted_flag"/>
    </preConditions>

    <sql splitStatements="true" stripComments="true" endDelimiter="\nGO">
      CREATE UNIQUE INDEX idx_unique_asset_name_deleted_flag ON "asset" (asset_name, deleted_flag)
        WHERE deleted_flag = false
    </sql>
  </changeSet>
</databaseChangeLog>