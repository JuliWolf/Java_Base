  <changeSet id="1696840913598-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="asset_type_attribute_type_assignment"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="asset_type_attribute_type_assignment" cascadeConstraints="true"/>
