        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="asset_type_id" baseTableName="asset_type_attribute_type_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_ATTRIBUTE_TYPE_ASSIGNMENT_ON_ASSET_TYPE" referencedColumnNames="asset_type_id" referencedTableName="asset_type" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="attribute_type_id" baseTableName="asset_type_attribute_type_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_ATTRIBUTE_TYPE_ASSIGNMENT_ON_ATTRIBUTE_TYPE" referencedColumnNames="attribute_type_id" referencedTableName="attribute_type" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="asset_type_attribute_type_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_ATTRIBUTE_TYPE_ASSIGNMENT_ON_CREATE_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="asset_type_attribute_type_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_ATTRIBUTE_TYPE_ASSIGNMENT_ON_DELETED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
