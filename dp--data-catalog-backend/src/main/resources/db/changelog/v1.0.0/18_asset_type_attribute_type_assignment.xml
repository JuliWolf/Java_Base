  <changeSet id="1696841102617-1" author="JuliWolf" dbms="postgresql">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="asset_type_attribute_type_assignment" columnName="asset_type_id"/>
      <columnExists tableName="asset_type_attribute_type_assignment" columnName="attribute_type_id"/>

      <columnExists tableName="asset_type_attribute_type_assignment" columnName="deleted_flag"/>
    </preConditions>

    <sql splitStatements="true" stripComments="true" endDelimiter="\nGO">
      CREATE UNIQUE INDEX idx_unique_asset_type_attribute_type_id_deleted_flag ON "asset_type_attribute_type_assignment" (asset_type_id, attribute_type_id, deleted_flag)
        WHERE deleted_flag = false
    </sql>
  </changeSet>
