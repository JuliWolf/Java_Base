<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd"
    objectQuotingStrategy="QUOTE_ALL_OBJECTS"
>
  <changeSet id="1700066666095-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="asset_hierarchy"/>
      </not>
    </preConditions>
    <createTable schemaName="public" tableName="asset_hierarchy">
        <column name="asset_hierarchy_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_asset_hierarchy"/>
        </column>
        <column name="parent_asset_id" type="UUID"/>
        <column name="child_asset_id" type="UUID"/>
        <column name="relation_id" type="UUID"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="child_asset_id" baseTableName="asset_hierarchy" baseTableSchemaName="public" constraintName="fk_asset_hierarchy_on_child_asset" referencedColumnNames="asset_id" referencedTableName="asset" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="asset_hierarchy" baseTableSchemaName="public" constraintName="fk_asset_hierarchy_on_create_by" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="asset_hierarchy" baseTableSchemaName="public" constraintName="fk_asset_hierarchy_on_deleted_by" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="parent_asset_id" baseTableName="asset_hierarchy" baseTableSchemaName="public" constraintName="fk_asset_hierarchy_on_parent_asset" referencedColumnNames="asset_id" referencedTableName="asset" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="relation_id" baseTableName="asset_hierarchy" baseTableSchemaName="public" constraintName="fk_asset_hierarchy_on_relation" referencedColumnNames="relation_id" referencedTableName="relation" referencedTableSchemaName="public"/>
  </changeSet>

  <changeSet id="1700140332358-1" author="JuliWolf" dbms="postgresql">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="asset_hierarchy" columnName="child_asset_id"/>
      <columnExists tableName="asset_hierarchy" columnName="parent_asset_id"/>
      <columnExists tableName="asset_hierarchy" columnName="relation_id"/>

      <columnExists tableName="asset_hierarchy" columnName="deleted_flag"/>
    </preConditions>

    <sql splitStatements="true" stripComments="true" endDelimiter="\nGO">
      CREATE UNIQUE INDEX idx_unique_asset_hierarchy_child_parent_relation_deleted_flag ON "asset_hierarchy" (child_asset_id, parent_asset_id, relation_id, deleted_flag)
        WHERE deleted_flag = false;
    </sql>
  </changeSet>
</databaseChangeLog>