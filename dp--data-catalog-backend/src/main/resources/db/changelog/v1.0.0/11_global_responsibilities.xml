<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">

  <changeSet id="1695641944865-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="global_responsibility"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="global_responsibility" cascadeConstraints="true"/>
    </rollback>

    <createTable schemaName="public" tableName="global_responsibility">
        <column name="global_responsibility_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_global_responsibility"/>
        </column>
        <column name="user_id" type="UUID"/>
        <column name="group_id" type="UUID"/>
        <column name="role_id" type="UUID"/>
        <column name="responsible_type" type="VARCHAR(255)"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="global_responsibility" baseTableSchemaName="public" constraintName="FK_GLOBAL_RESPONSIBILITY_ON_CREATE_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="global_responsibility" baseTableSchemaName="public" constraintName="FK_GLOBAL_RESPONSIBILITY_ON_DELETED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="group_id" baseTableName="global_responsibility" baseTableSchemaName="public" constraintName="FK_GLOBAL_RESPONSIBILITY_ON_GROUP" referencedColumnNames="group_id" referencedTableName="group" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="role_id" baseTableName="global_responsibility" baseTableSchemaName="public" constraintName="FK_GLOBAL_RESPONSIBILITY_ON_ROLE" referencedColumnNames="role_id" referencedTableName="role" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="global_responsibility" baseTableSchemaName="public" constraintName="FK_GLOBAL_RESPONSIBILITY_ON_USER" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
  </changeSet>

  <changeSet id="1695652249201-1" author="JuliWolf" dbms="postgresql">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="global_responsibility" columnName="role_id"/>
      <columnExists tableName="global_responsibility" columnName="responsible_type"/>
      <columnExists tableName="global_responsibility" columnName="user_id"/>
      <columnExists tableName="global_responsibility" columnName="group_id"/>
      <columnExists tableName="global_responsibility" columnName="deleted_flag"/>
    </preConditions>

    <sql splitStatements="true" stripComments="true" endDelimiter="\nGO">
      CREATE UNIQUE INDEX uk_role_responsible_type_user
        ON global_responsibility (role_id, responsible_type, user_id)
        WHERE deleted_flag = false;
      CREATE UNIQUE INDEX uk_role_responsible_type_group
        ON global_responsibility (role_id, responsible_type, group_id)
        WHERE deleted_flag = false;
    </sql>
  </changeSet>
</databaseChangeLog>