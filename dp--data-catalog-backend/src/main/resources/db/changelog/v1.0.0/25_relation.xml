<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd"
    objectQuotingStrategy="QUOTE_ALL_OBJECTS"
>
  <changeSet id="1700066666095-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="relation"/>
      </not>
    </preConditions>
    <createTable schemaName="public" tableName="relation">
        <column name="relation_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_relation"/>
        </column>
        <column name="relation_type_id" type="UUID"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="relation" baseTableSchemaName="public" constraintName="fk_relation_on_create_by" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="relation" baseTableSchemaName="public" constraintName="fk_relation_on_deleted_by" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="relation_type_id" baseTableName="relation" baseTableSchemaName="public" constraintName="fk_relation_on_relation_type" referencedColumnNames="relation_type_id" referencedTableName="relation_type" referencedTableSchemaName="public"/>
  </changeSet>
</databaseChangeLog>