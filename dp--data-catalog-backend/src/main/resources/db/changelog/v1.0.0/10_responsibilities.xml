<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">

  <changeSet id="1695671699239-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="responsibility"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="responsibility" cascadeConstraints="true"/>
    </rollback>
    <createTable schemaName="public" tableName="responsibility">
        <column name="responsibility_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_responsibility"/>
        </column>
        <column name="responsible_id" type="UUID">
            <constraints nullable="false"/>
        </column>
        <column name="role_id" type="UUID">
            <constraints nullable="false"/>
        </column>
        <column name="responsible_type" type="VARCHAR(255)"/>
        <column name="inherited_flag" type="BOOLEAN"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="responsibility" baseTableSchemaName="public" constraintName="FK_RESPONSIBILITY_ON_CREATE_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="responsibility" baseTableSchemaName="public" constraintName="FK_RESPONSIBILITY_ON_DELETED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="responsible_id" baseTableName="responsibility" baseTableSchemaName="public" constraintName="FK_RESPONSIBILITY_ON_RESPONSIBLE" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="role_id" baseTableName="responsibility" baseTableSchemaName="public" constraintName="FK_RESPONSIBILITY_ON_ROLE" referencedColumnNames="role_id" referencedTableName="role" referencedTableSchemaName="public"/>
  </changeSet>
</databaseChangeLog>