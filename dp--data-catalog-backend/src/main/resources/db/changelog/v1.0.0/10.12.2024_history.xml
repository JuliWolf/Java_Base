  <changeSet id="1733834376521-1" author="juliwolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="asset_history"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="asset_history" cascadeConstraints="true"/>
    </rollback>
    <createTable schemaName="public" tableName="asset_history">
        <column name="asset_history_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_asset_history"/>
        </column>
        <column name="asset_id" type="UUID"/>
        <column name="asset_name" type="VARCHAR(255)"/>
        <column name="asset_type_id" type="UUID"/>
        <column name="asset_displayname" type="VARCHAR(255)"/>
        <column name="source_language" type="UUID"/>
        <column name="lifecycle_status" type="UUID"/>
        <column name="stewardship_status" type="UUID"/>
        <column name="created_on" type="DATETIME"/>
        <column name="created_by" type="UUID"/>
        <column name="last_modified_on" type="DATETIME"/>
        <column name="last_modified_by" type="UUID"/>
        <column name="deleted_flag" type="BOOLEAN"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
        <column name="valid_from" type="DATETIME"/>
        <column name="valid_to" type="DATETIME"/>
    </createTable>
    <createIndex indexName="idx_asset_id_valid_from_valid_to" schemaName="public" tableName="asset_history">
        <column name="asset_id"/>
        <column name="valid_from"/>
        <column name="valid_to"/>
    </createIndex>
  </changeSet>

