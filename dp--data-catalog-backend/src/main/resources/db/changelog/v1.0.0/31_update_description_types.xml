    <modifyDataType tableName="attribute_type" columnName="attribute_type_description" newDataType="varchar(512)"
                    schemaName="public"/>
  </changeSet>
  <changeSet id="1701173232239-1" author="juliwolf">
    <modifyDataType tableName="relation_type_component" columnName="relation_type_component_description"
                    newDataType="varchar(512)" schemaName="public"/>
  </changeSet>
  <changeSet id="1701173255614-1" author="juliwolf">
    <modifyDataType tableName="status" columnName="status_description" newDataType="varchar(512)" schemaName="public"/>
