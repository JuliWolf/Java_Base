<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">


  <changeSet id="1709747056689-1" author="juliwolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="log"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="log" cascadeConstraints="true"/>
    </rollback>
    <createTable schemaName="public" tableName="log">
        <column name="log_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_log"/>
        </column>
        <column name="request_type" type="varchar(10)"/>
        <column name="user_id" type="UUID"/>
        <column name="controller_name" type="varchar(100)"/>
        <column name="path_variables" type="jsonb"/>
        <column name="request_json" type="jsonb"/>
        <column name="response_json" type="jsonb"/>
        <column name="response_code" type="smallint"/>
        <column name="logged_on" type="DATETIME"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="log" baseTableSchemaName="public" constraintName="FK_LOG_ON_USER" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
  </changeSet>
</databaseChangeLog>