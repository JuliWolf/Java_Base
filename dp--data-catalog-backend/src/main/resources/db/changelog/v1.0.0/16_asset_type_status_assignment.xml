<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">

  <changeSet id="1696840775113-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="asset_type_status_assignment"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="asset_type_status_assignment" cascadeConstraints="true"/>
    </rollback>
    <createTable schemaName="public" tableName="asset_type_status_assignment">
        <column name="asset_type_status_assignment_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_asset_type_status_assignment"/>
        </column>
        <column name="asset_type_id" type="UUID"/>
        <column name="status_type" type="VARCHAR(255)"/>
        <column name="status_id" type="UUID"/>
        <column defaultValueBoolean="false" name="inherited_flag" type="boolean"/>
        <column name="parent_asset_type_id" type="UUID"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="asset_type_id" baseTableName="asset_type_status_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_STATUS_ASSIGNMENT_ON_ASSET_TYPE" referencedColumnNames="asset_type_id" referencedTableName="asset_type" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="asset_type_status_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_STATUS_ASSIGNMENT_ON_CREATE_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="asset_type_status_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_STATUS_ASSIGNMENT_ON_DELETED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="parent_asset_type_id" baseTableName="asset_type_status_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_STATUS_ASSIGNMENT_ON_PARENT_ASSET_TYPE" referencedColumnNames="asset_type_id" referencedTableName="asset_type" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="status_id" baseTableName="asset_type_status_assignment" baseTableSchemaName="public" constraintName="FK_ASSET_TYPE_STATUS_ASSIGNMENT_ON_STATUS" referencedColumnNames="status_id" referencedTableName="status" referencedTableSchemaName="public"/>
  </changeSet>

  <changeSet id="1696840975203-1" author="JuliWolf" dbms="postgresql">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="asset_type_status_assignment" columnName="asset_type_id"/>
      <columnExists tableName="asset_type_status_assignment" columnName="status_type"/>
      <columnExists tableName="asset_type_status_assignment" columnName="status_id"/>

      <columnExists tableName="asset_type_status_assignment" columnName="deleted_flag"/>
    </preConditions>

    <sql splitStatements="true" stripComments="true" endDelimiter="\nGO">
      CREATE UNIQUE INDEX idx_unique_asset_type_status_type_status_id_deleted_flag ON "asset_type_status_assignment" (asset_type_id, status_type, status_id, deleted_flag)
        WHERE deleted_flag = false
    </sql>
  </changeSet>
</databaseChangeLog>