<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">

  <changeSet id="1696504833966-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="attribute_type_allowed_value"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="attribute_type_allowed_value" cascadeConstraints="true"/>
    </rollback>

    <createTable schemaName="public" tableName="attribute_type_allowed_value">
        <column name="value_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_attribute_type_allowed_value"/>
        </column>
        <column name="attribute_type_id" type="UUID"/>
        <column name="value" type="VARCHAR(255)"/>
        <column name="source_language" type="UUID"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="attribute_type_id" baseTableName="attribute_type_allowed_value" baseTableSchemaName="public" constraintName="FK_ATTRIBUTE_TYPE_ALLOWED_VALUE_ON_ATTRIBUTE_TYPE" referencedColumnNames="attribute_type_id" referencedTableName="attribute_type" referencedTableSchemaName="public" onDelete="CASCADE"/>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="attribute_type_allowed_value" baseTableSchemaName="public" constraintName="FK_ATTRIBUTE_TYPE_ALLOWED_VALUE_ON_CREATE_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="attribute_type_allowed_value" baseTableSchemaName="public" constraintName="FK_ATTRIBUTE_TYPE_ALLOWED_VALUE_ON_DELETED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="source_language" baseTableName="attribute_type_allowed_value" baseTableSchemaName="public" constraintName="FK_ATTRIBUTE_TYPE_ALLOWED_VALUE_ON_SOURCE_LANGUAGE" referencedColumnNames="language_id" referencedTableName="language" referencedTableSchemaName="public"/>
  </changeSet>

  <changeSet id="1696504962357-1" author="JuliWolf" dbms="postgresql">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="attribute_type_allowed_value" columnName="attribute_type_id"/>
      <columnExists tableName="attribute_type_allowed_value" columnName="value"/>

      <columnExists tableName="attribute_type_allowed_value" columnName="deleted_flag"/>
    </preConditions>

    <sql splitStatements="true" stripComments="true" endDelimiter="\nGO">
      CREATE UNIQUE INDEX idx_unique_attribute_type_id_value_deleted_flag ON "attribute_type_allowed_value" (attribute_type_id, value, deleted_flag)
        WHERE deleted_flag = false
    </sql>
  </changeSet>
</databaseChangeLog>