<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.18.xsd">

  <changeSet id="1695288684832-1" author="JuliWolf">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="relation_type"/>
      </not>
    </preConditions>

    <rollback>
      <dropTable tableName="relation_type" cascadeConstraints="true"/>
    </rollback>
    <createTable schemaName="public" tableName="relation_type">
        <column name="relation_type_id" type="UUID">
            <constraints nullable="false" primaryKey="true" primaryKeyName="pk_relation_type"/>
        </column>
        <column name="relation_type_name" type="VARCHAR(255)"/>
        <column name="relation_type_description" type="VARCHAR(255)"/>
        <column name="relation_type_asset_number" type="INT"/>
        <column name="is_inheritance" type="BOOLEAN"/>
        <column name="source_language" type="UUID"/>
        <column name="created_on" type="DATETIME"/>
        <column name="create_by" type="UUID"/>
        <column name="last_modified_on" type="DATETIME"/>
        <column name="last_modified_by" type="UUID"/>
        <column defaultValueBoolean="false" name="deleted_flag" type="boolean"/>
        <column name="deleted_on" type="DATETIME"/>
        <column name="deleted_by" type="UUID"/>
    </createTable>
    <addForeignKeyConstraint baseColumnNames="create_by" baseTableName="relation_type" baseTableSchemaName="public" constraintName="FK_RELATION_TYPE_ON_CREATE_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="deleted_by" baseTableName="relation_type" baseTableSchemaName="public" constraintName="FK_RELATION_TYPE_ON_DELETED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="last_modified_by" baseTableName="relation_type" baseTableSchemaName="public" constraintName="FK_RELATION_TYPE_ON_LAST_MODIFIED_BY" referencedColumnNames="user_id" referencedTableName="user" referencedTableSchemaName="public"/>
    <addForeignKeyConstraint baseColumnNames="source_language" baseTableName="relation_type" baseTableSchemaName="public" constraintName="FK_RELATION_TYPE_ON_SOURCE_LANGUAGE" referencedColumnNames="language_id" referencedTableName="language" referencedTableSchemaName="public"/>
  </changeSet>

  <changeSet id="1695288546611-1" author="JuliWolf" dbms="postgresql">
    <preConditions onFail="MARK_RAN">
      <columnExists tableName="relation_type" columnName="relation_type_name"/>

      <columnExists tableName="relation_type" columnName="deleted_flag"/>
    </preConditions>

    <sql splitStatements="true" stripComments="true" endDelimiter="\nGO">
      CREATE UNIQUE INDEX idx_unique_relation_type_name_deleted_flag ON relation_type (relation_type_name, deleted_flag)
        WHERE deleted_flag = false
    </sql>
  </changeSet>
</databaseChangeLog>